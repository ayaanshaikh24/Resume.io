---
import Layout from '../layouts/Layout.astro';
import { PortfolioBuilder } from '../components/PortfolioBuilder';
---

<Layout>
	<!-- App Shell Layout -->
	<div class="flex flex-col min-h-screen">
		
		<!-- Top Navigation Header -->
		<header class="sticky top-0 z-50 h-16 bg-canvas border-b border-hairline px-4 md:px-8 flex items-center justify-between">
			{/* Brand Wordmark (Document Logo + Wordmark) */}
			<div class="flex items-center gap-2.5 select-none">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
					<defs>
						<linearGradient id="logo-bookmark-grad" x1="0%" y1="0%" x2="0%" y2="100%">
							<stop offset="0%" stop-color="#FFA47A" />
							<stop offset="100%" stop-color="#D97757" />
						</linearGradient>
					</defs>
					<rect x="3" y="5" width="15" height="16" rx="3.5" fill="none" stroke="#E5DCD0" stroke-width="2" />
					<line x1="6.5" y1="10" x2="11.5" y2="10" stroke="#E5DCD0" stroke-width="1.8" stroke-linecap="round" />
					<line x1="6.5" y1="13.5" x2="14.5" y2="13.5" stroke="#E5DCD0" stroke-width="1.8" stroke-linecap="round" />
					<line x1="6.5" y1="17" x2="10.5" y2="17" stroke="#E5DCD0" stroke-width="1.8" stroke-linecap="round" />
					<path d="M12 3h6v9.5l-3-2.5-3 2.5V3z" fill="url(#logo-bookmark-grad)" />
				</svg>
				<span class="font-sans text-xl font-medium tracking-tight text-ink">
					resumeio
				</span>
			</div>
			
			{/* App Title (SEO compliant hidden H1, page details visible via brand/preview) */}
			<h1 class="sr-only">resumeio | Warm Canvas Resume & Portfolio Generator</h1>
			
			{/* Navigation links & Actions */}
			<nav class="flex items-center gap-4">
				<a 
					href="https://github.com/ayaan" 
					target="_blank" 
					rel="noopener noreferrer" 
					class="text-xs font-sans font-medium text-muted hover:text-primary transition-colors flex items-center gap-1.5"
				>
					{/* Github SVG */}
					<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
						<path fillRule="evenodd" clipRule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
					</svg>
					<span>GitHub Profile</span>
				</a>
			</nav>
		</header>

		<!-- Main Workspace Area -->
		<main class="flex-1 bg-surface-soft min-h-[calc(100vh-64px)]">
			<PortfolioBuilder client:load />
		</main>

	</div>
</Layout>
